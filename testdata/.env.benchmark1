KEY_WITH_EQUALS =   value=with=equals
KEY_WITH_HASH =   value#with#hash
KEY_WITH_BACKSLASH =   value\with\backslash
KEY_WITH_COLON =   value:with:colon
KEY_WITH_SEMICOLON =   value;with:semicolon
KEY_WITH_COMMA =   value,with,comma
KEY_WITH_DOT =   value.with.dot
KEY_WITH_SLASH =   value/with/slash
KEY_WITH_QUESTION =   value?with?question
KEY_WITH_AMPERSAND =   value&with&ampersand
KEY_WITH_PERCENT =   value%with%percent
KEY_WITH_CARET =   value^with^caret
KEY_WITH_UNDERSCORE =   value_with_underscore
KEY_WITH_DASH =   value-with-dash
KEY_WITH_PLUS =   value+with+plus
KEY_WITH_TILDE =   value~with~tilde
KEY_WITH_BACKTICK =   value`with`backtick
KEY_WITH_PIPE =   value|with|pipe
KEY_WITH_SPACE =   value with space
KEY_WITH_ESCAPED_CHARACTERS =   value with escaped characters: \n, \t, \", \', \\, and \\
KEY_WITH_UNICODE_CHARACTERS =   value with unicode characters: ü, ñ, and 漢字
